#!/bin/bash
# pve-microvm-template — fetch an OCI image and create a PVE VM template
#
# Creates a ready-to-clone microvm template from an OCI container image.
# The template VM can be cloned instantly to spin up new microvm guests.
#
# Usage:
#   pve-microvm-template                          # use defaults from config
#   pve-microvm-template --image ubuntu:22.04     # override image
#   pve-microvm-template --vmid 9001              # override template VMID
#   pve-microvm-template --list                   # list existing microvm templates
#
# After creation:
#   qm clone 9000 <new-vmid> --name my-sandbox    # instant linked clone

set -euo pipefail

PROG=$(basename "$0")
CONF="/etc/pve-microvm/images.conf"
CONF_DEFAULT="/usr/share/pve-microvm/microvm-images.conf"
CACHE_DIR="/var/cache/pve-microvm"

# Defaults (overridden by config or flags)
IMAGE="debian:trixie-slim"
TEMPLATE_VMID="9000"
TEMPLATE_NAME="microvm-trixie"
STORAGE="local-lvm"
DISK_SIZE="2G"
MEMORY="256"
CORES="1"
BRIDGE="vmbr0"
TAGS="microvm,template"
# Auto-detect kernel + initrd
if [ -f "/usr/share/pve-microvm/vmlinuz" ]; then
    KERNEL="/usr/share/pve-microvm/vmlinuz"
    if [ -f "/usr/share/pve-microvm/initrd" ]; then
        INITRD="/usr/share/pve-microvm/initrd"
    else
        INITRD=""
    fi
else
    KERNEL="/boot/vmlinuz-$(uname -r)"
    INITRD="/boot/initrd.img-$(uname -r)"
fi
APPEND="console=ttyS0 root=/dev/vda rw quiet"

log() { echo "[$PROG] $*"; }
die() { echo "[$PROG] ERROR: $*" >&2; exit 1; }

usage() {
    cat <<EOF
Usage: $PROG [OPTIONS]

Create a PVE VM template from an OCI image for instant microvm cloning.

Options:
  --image IMAGE      OCI image (default: $IMAGE)
  --vmid VMID        Template VM ID (default: $TEMPLATE_VMID)
  --name NAME        Template name (default: $TEMPLATE_NAME)
  --storage STORE    PVE storage (default: $STORAGE)
  --disk-size SIZE   Disk size (default: $DISK_SIZE)
  --list             List existing microvm templates
  --refresh          Re-fetch image even if template exists
  --help             Show this help

After creation:
  qm clone $TEMPLATE_VMID <new-vmid> --name my-sandbox
  qm set <new-vmid> --memory 512   # optionally override resources
  qm start <new-vmid>
  qm terminal <new-vmid>
EOF
    exit "${1:-0}"
}

# Load config file
load_config() {
    local conf="${CONF}"
    [ -f "$conf" ] || conf="$CONF_DEFAULT"
    [ -f "$conf" ] || return 0

    while IFS='=' read -r key value; do
        key=$(echo "$key" | tr -d ' ')
        value=$(echo "$value" | sed 's/^ *//' | sed 's/ *$//')
        case "$key" in
            image)          IMAGE="$value" ;;
            template_vmid)  TEMPLATE_VMID="$value" ;;
            template_name)  TEMPLATE_NAME="$value" ;;
            storage)        STORAGE="$value" ;;
            disk_size)      DISK_SIZE="$value" ;;
            memory)         MEMORY="$value" ;;
            cores)          CORES="$value" ;;
            bridge)         BRIDGE="$value" ;;
            tags)           TAGS="$value" ;;
            kernel)         KERNEL="$value" ;;
            append)         APPEND="$value" ;;
        esac
    done < <(grep -v '^#\|^\[' "$conf" | grep '=')
}

list_templates() {
    log "Existing microvm templates:"
    qm list 2>/dev/null | while read -r vmid name status mem pid; do
        [ "$vmid" = "VMID" ] && continue
        conf="/etc/pve/qemu-server/${vmid}.conf"
        [ -f "$conf" ] || continue
        if grep -q 'machine:.*microvm' "$conf" 2>/dev/null && grep -q 'template:' "$conf" 2>/dev/null; then
            echo "  VMID $vmid  name=$name  status=$status"
        fi
    done
}

REFRESH=0
ACTION="create"

# Parse args
load_config
while [[ $# -gt 0 ]]; do
    case "$1" in
        --image)     IMAGE="$2"; shift 2 ;;
        --vmid)      TEMPLATE_VMID="$2"; shift 2 ;;
        --name)      TEMPLATE_NAME="$2"; shift 2 ;;
        --storage)   STORAGE="$2"; shift 2 ;;
        --disk-size) DISK_SIZE="$2"; shift 2 ;;
        --list)      ACTION="list"; shift ;;
        --refresh)   REFRESH=1; shift ;;
        --help|-h)   usage 0 ;;
        *)           die "unknown argument: $1" ;;
    esac
done

if [ "$ACTION" = "list" ]; then
    list_templates
    exit 0
fi

# Check if template already exists
if qm config "$TEMPLATE_VMID" >/dev/null 2>&1; then
    if [ "$REFRESH" -eq 0 ]; then
        log "Template VM $TEMPLATE_VMID already exists. Use --refresh to recreate."
        exit 0
    fi
    log "Removing existing template $TEMPLATE_VMID"
    qm destroy "$TEMPLATE_VMID" --purge 2>/dev/null || true
fi

# Validate tools
for tool in skopeo umoci qemu-img mkfs.ext4; do
    command -v "$tool" >/dev/null 2>&1 || die "required tool not found: $tool"
done

if [ ! -f "$KERNEL" ]; then
    # Fallback to host kernel
    KERNEL="/boot/vmlinuz-$(uname -r)"
    INITRD="/boot/initrd.img-$(uname -r)"
    [ -f "$KERNEL" ] || die "no kernel found (neither shipped nor host)"
    log "Using host kernel: $KERNEL"
fi

log "Creating microvm template from $IMAGE"
log "  VMID:    $TEMPLATE_VMID"
log "  Name:    $TEMPLATE_NAME"
log "  Storage: $STORAGE"
log "  Disk:    $DISK_SIZE"

# Work directory
mkdir -p "$CACHE_DIR"
WORKDIR=$(mktemp -d "$CACHE_DIR/build.XXXXXX")
trap 'rm -rf "$WORKDIR"' EXIT

OCI_DIR="$WORKDIR/oci"
BUNDLE_DIR="$WORKDIR/bundle"
ROOTFS_DIR="$BUNDLE_DIR/rootfs"

# Step 1: Pull image
log "Pulling $IMAGE..."
FULL_IMAGE="$IMAGE"
[[ "$FULL_IMAGE" == *"/"* ]] || FULL_IMAGE="docker.io/library/$FULL_IMAGE"
skopeo copy "docker://$FULL_IMAGE" "oci:$OCI_DIR:latest" >/dev/null 2>&1

# Step 2: Unpack
log "Unpacking rootfs..."
umoci unpack --image "$OCI_DIR:latest" "$BUNDLE_DIR" >/dev/null 2>&1

# Step 3: Prepare for microvm boot
log "Preparing rootfs..."
for dir in proc sys dev dev/pts run tmp; do
    mkdir -p "$ROOTFS_DIR/$dir"
done

# Install init system for the rootfs
MICROVM_INIT="/usr/share/pve-microvm/microvm-init"

if [ -d "$ROOTFS_DIR/lib/systemd/system" ] && [ -f "$ROOTFS_DIR/lib/systemd/systemd" ]; then
    log "systemd detected — configuring for serial console"
    mkdir -p "$ROOTFS_DIR/etc/systemd/system/getty.target.wants"
    ln -sf /lib/systemd/system/serial-getty@.service \
        "$ROOTFS_DIR/etc/systemd/system/getty.target.wants/serial-getty@ttyS0.service" 2>/dev/null || true
    sed -i 's|^root:[^:]*:|root::|' "$ROOTFS_DIR/etc/shadow" 2>/dev/null || true

elif [ -f "$ROOTFS_DIR/bin/busybox" ]; then
    log "busybox detected — configuring inittab for ttyS0"
    [ -f "$ROOTFS_DIR/sbin/init" ] || ln -sf ../bin/busybox "$ROOTFS_DIR/sbin/init"
    cat > "$ROOTFS_DIR/etc/inittab" <<'INITTAB'
::sysinit:/bin/mount -t proc proc /proc
::sysinit:/bin/mount -t sysfs sys /sys
::sysinit:/bin/mount -t devtmpfs dev /dev
::sysinit:/bin/mkdir -p /dev/pts
::sysinit:/bin/mount -t devpts devpts /dev/pts
::sysinit:/bin/hostname microvm
ttyS0::respawn:/bin/sh
::shutdown:/bin/umount -a -r
INITTAB

else
    log "no init found — installing microvm-init"
    if [ -f "$MICROVM_INIT" ]; then
        install -m 755 "$MICROVM_INIT" "$ROOTFS_DIR/sbin/microvm-init"
        ln -sf microvm-init "$ROOTFS_DIR/sbin/init"
    fi
fi

# Set empty root password for serial login
if [ -f "$ROOTFS_DIR/etc/shadow" ]; then
    sed -i 's|^root:[^:]*:|root::|' "$ROOTFS_DIR/etc/shadow" 2>/dev/null || true
fi

# Install the setup script for first-boot package installation
MICROVM_SETUP="/usr/share/pve-microvm/microvm-setup"
if [ -f "$MICROVM_SETUP" ]; then
    log "Installing first-boot setup script..."
    install -m 755 "$MICROVM_SETUP" "$ROOTFS_DIR/usr/local/bin/microvm-setup"

    # Create a systemd service to run it on first boot (if systemd will be used)
    if [ -d "$ROOTFS_DIR/etc/systemd/system" ] || [ -d "$ROOTFS_DIR/lib/systemd" ]; then
        mkdir -p "$ROOTFS_DIR/etc/systemd/system/multi-user.target.wants"
        cat > "$ROOTFS_DIR/etc/systemd/system/microvm-setup.service" <<'SVCUNIT'
[Unit]
Description=microvm first-boot setup
ConditionPathExists=!/etc/microvm-setup-done
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/microvm-setup
RemainAfterExit=yes
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
SVCUNIT
        ln -sf ../microvm-setup.service \
            "$ROOTFS_DIR/etc/systemd/system/multi-user.target.wants/microvm-setup.service"
    else
        # For non-systemd: add to microvm-init's boot sequence
        # The setup will run when the user manually calls it
        log "No systemd — run 'microvm-setup' manually after first boot"
    fi
fi

# DNS defaults (needed for chroot package install)
[ -f "$ROOTFS_DIR/etc/resolv.conf" ] || echo "nameserver 1.1.1.1" > "$ROOTFS_DIR/etc/resolv.conf"

# Step 4: Install essential packages via chroot
# trixie-slim has no networking tools — install them at build time
if [ -f "$ROOTFS_DIR/usr/bin/apt-get" ] || [ -f "$ROOTFS_DIR/usr/bin/dpkg" ]; then
    log "Installing base packages via chroot..."

    # Bind-mount host resources for chroot
    mount --bind /proc "$ROOTFS_DIR/proc" 2>/dev/null || true
    mount --bind /sys "$ROOTFS_DIR/sys" 2>/dev/null || true
    mount --bind /dev "$ROOTFS_DIR/dev" 2>/dev/null || true
    mount --bind /dev/pts "$ROOTFS_DIR/dev/pts" 2>/dev/null || true

    # Ensure apt sources exist
    if [ ! -f "$ROOTFS_DIR/etc/apt/sources.list" ] && \
       [ -z "$(find "$ROOTFS_DIR/etc/apt/sources.list.d" -name '*.sources' -o -name '*.list' 2>/dev/null)" ]; then
        mkdir -p "$ROOTFS_DIR/etc/apt/sources.list.d"
        cat > "$ROOTFS_DIR/etc/apt/sources.list.d/debian.sources" <<'APTSRC'
Types: deb
URIs: http://deb.debian.org/debian
Suites: trixie trixie-updates
Components: main
Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg
APTSRC
    fi

    # Install packages
    chroot "$ROOTFS_DIR" /bin/bash -c '
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -qq 2>/dev/null
        apt-get install -y -qq --no-install-recommends \
            iproute2 isc-dhcp-client systemd systemd-sysv \
            openssh-server cloud-init qemu-guest-agent \
            ca-certificates curl 2>/dev/null

        # Enable serial console and essential services
        systemctl enable serial-getty@ttyS0.service 2>/dev/null || true
        systemctl enable qemu-guest-agent 2>/dev/null || true
        systemctl enable ssh 2>/dev/null || true
        systemctl enable cloud-init 2>/dev/null || true
        systemctl enable systemd-networkd 2>/dev/null || true
        systemctl enable systemd-resolved 2>/dev/null || true

        # Create a custom console service that does not depend on udev device units
        # The stock serial-getty@ttyS0 requires dev-ttyS0.device which needs udev
        # events that devtmpfs from initrd does not generate
        systemctl disable serial-getty@ttyS0.service 2>/dev/null || true
        printf "[Unit]\nDescription=microvm serial console\nAfter=systemd-user-sessions.service\n\n[Service]\nExecStart=-/sbin/agetty --autologin root --noclear ttyS0 linux\nRestart=always\nRestartSec=0\nType=idle\n\n[Install]\nWantedBy=multi-user.target\n" > /etc/systemd/system/microvm-console.service
        systemctl enable microvm-console.service 2>/dev/null || true

        # Fix guest agent: remove device binding -- same udev issue
        # the virtio-serial port exists but udev may not create the symlink
        mkdir -p /etc/systemd/system/qemu-guest-agent.service.d
        printf "[Unit]\nBindsTo=\nAfter=\n\n[Service]\nExecStart=\nExecStart=-/usr/sbin/qemu-ga\n" > /etc/systemd/system/qemu-guest-agent.service.d/microvm.conf

        # Configure cloud-init for PVE nocloud
        mkdir -p /etc/cloud/cloud.cfg.d
        cat > /etc/cloud/cloud.cfg.d/99-pve.cfg <<CICFG
datasource_list: [NoCloud, ConfigDrive, None]
datasource:
  NoCloud:
    fs_label: cidata
CICFG

        # Set empty root password
        sed -i "s|^root:[^:]*:|root::|" /etc/shadow 2>/dev/null || true

        # Clean up
        apt-get clean 2>/dev/null || true
        rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
    ' 2>&1 || log "warning: chroot package install had errors"

    # Unmount
    umount "$ROOTFS_DIR/dev/pts" 2>/dev/null || true
    umount "$ROOTFS_DIR/dev" 2>/dev/null || true
    umount "$ROOTFS_DIR/sys" 2>/dev/null || true
    umount "$ROOTFS_DIR/proc" 2>/dev/null || true

    log "Base packages installed."
else
    log "No apt-get found — skipping chroot package install"
fi

# Step 4: Create disk image
log "Creating $DISK_SIZE disk..."
RAW="$WORKDIR/disk.raw"
truncate -s "$DISK_SIZE" "$RAW"
mkfs.ext4 -F -L microvm-root -d "$ROOTFS_DIR" "$RAW" >/dev/null 2>&1

QCOW2="$WORKDIR/disk.qcow2"
qemu-img convert -f raw -O qcow2 "$RAW" "$QCOW2"

# Step 5: Create template VM
log "Creating template VM $TEMPLATE_VMID..."
KERNEL_ARGS="-kernel $KERNEL -append \"$APPEND\""
if [ -n "$INITRD" ] && [ -f "$INITRD" ]; then
    KERNEL_ARGS="-kernel $KERNEL -initrd $INITRD -append \"$APPEND\""
fi

qm create "$TEMPLATE_VMID" \
    --machine microvm \
    --name "$TEMPLATE_NAME" \
    --memory "$MEMORY" \
    --cores "$CORES" \
    --net0 "virtio,bridge=$BRIDGE" \
    --serial0 socket \
    --vga serial0 \
    --agent 1 \
    --tags "$TAGS" \
    --args "$KERNEL_ARGS"

# Remove options that microvm doesn't support (auto-set by qm create)
qm set "$TEMPLATE_VMID" --delete vmgenid --delete smbios1 2>/dev/null || true

# Step 6: Import disk
log "Importing disk to $STORAGE..."
qm importdisk "$TEMPLATE_VMID" "$QCOW2" "$STORAGE" --format qcow2 >/dev/null 2>&1
qm set "$TEMPLATE_VMID" --scsi0 "$STORAGE:vm-${TEMPLATE_VMID}-disk-0"

# Step 7: Add cloud-init drive
log "Adding cloud-init drive..."
qm set "$TEMPLATE_VMID" --scsi1 "$STORAGE:cloudinit" 2>/dev/null || \
    log "warning: could not add cloud-init drive"

# Set cloud-init defaults
qm set "$TEMPLATE_VMID" --ciuser root --ipconfig0 ip=dhcp 2>/dev/null || true

# Step 8: Convert to template
log "Converting to template..."
qm template "$TEMPLATE_VMID"

log ""
log "=== Template ready ==="
log ""
log "Clone a new microvm:"
log "  qm clone $TEMPLATE_VMID <new-vmid> --name my-sandbox --full"
log ""
log "Set SSH key (optional):"
log "  qm set <new-vmid> --sshkeys ~/.ssh/authorized_keys"
log ""
log "Start and connect:"
log "  qm start <new-vmid>"
log "  qm terminal <new-vmid>"
