#!/bin/bash
# pve-microvm-template — fetch an OCI image and create a PVE VM template
#
# Creates a ready-to-clone microvm template from an OCI container image.
# The template VM can be cloned instantly to spin up new microvm guests.
#
# Usage:
#   pve-microvm-template                          # use defaults from config
#   pve-microvm-template --image ubuntu:22.04     # override image
#   pve-microvm-template --vmid 9001              # override template VMID
#   pve-microvm-template --list                   # list existing microvm templates
#
# After creation:
#   qm clone 9000 <new-vmid> --name my-sandbox    # instant linked clone

set -euo pipefail

PROG=$(basename "$0")
CONF="/etc/pve-microvm/images.conf"
CONF_DEFAULT="/usr/share/pve-microvm/microvm-images.conf"
CACHE_DIR="/var/cache/pve-microvm"

# Defaults (overridden by config or flags)
IMAGE="debian:trixie-slim"
TEMPLATE_VMID="9000"
TEMPLATE_NAME="microvm-trixie"
STORAGE="local-lvm"
DISK_SIZE="2G"
MEMORY="256"
CORES="1"
BRIDGE="vmbr0"
TAGS="microvm,template"
INSTALL_DOCKER=1
INSTALL_SSH=1
INSTALL_AGENT=1
PROFILE=""
# Auto-detect kernel + initrd
if [ -f "/usr/share/pve-microvm/vmlinuz" ]; then
    KERNEL="/usr/share/pve-microvm/vmlinuz"
    if [ -f "/usr/share/pve-microvm/initrd" ]; then
        INITRD="/usr/share/pve-microvm/initrd"
    else
        INITRD=""
    fi
else
    KERNEL="/boot/vmlinuz-$(uname -r)"
    INITRD="/boot/initrd.img-$(uname -r)"
fi
APPEND="console=ttyS0 root=/dev/vda rw quiet"

log() { echo "[$PROG] $*"; }
die() { echo "[$PROG] ERROR: $*" >&2; exit 1; }

usage() {
    cat <<EOF
Usage: $PROG [OPTIONS]

Create a PVE VM template from an OCI image for instant microvm cloning.

Options:
  --image IMAGE      OCI image (default: $IMAGE)
  --vmid VMID        Template VM ID (default: $TEMPLATE_VMID)
  --name NAME        Template name (default: $TEMPLATE_NAME)
  --storage STORE    PVE storage (default: $STORAGE)
  --disk-size SIZE   Disk size (default: $DISK_SIZE)
  --profile PROFILE  minimal|standard|full (see below)
  --no-docker        Skip Docker CE installation
  --no-ssh           Skip OpenSSH server installation
  --no-agent         Skip QEMU guest agent installation
  --list             List existing microvm templates
  --refresh          Re-fetch image even if template exists
  --help             Show this help

Profiles:
  minimal   — busybox init, no packages, no network services (fastest boot)
  standard  — systemd, cloud-init, DHCP, SSH, guest agent (default)
  full      — standard + Docker CE

After creation:
  qm clone $TEMPLATE_VMID <new-vmid> --name my-sandbox
  qm set <new-vmid> --memory 512   # optionally override resources
  qm start <new-vmid>
  qm terminal <new-vmid>
EOF
    exit "${1:-0}"
}

# Load config file
load_config() {
    local conf="${CONF}"
    [ -f "$conf" ] || conf="$CONF_DEFAULT"
    [ -f "$conf" ] || return 0

    while IFS='=' read -r key value; do
        key=$(echo "$key" | tr -d ' ')
        value=$(echo "$value" | sed 's/^ *//' | sed 's/ *$//')
        case "$key" in
            image)          IMAGE="$value" ;;
            template_vmid)  TEMPLATE_VMID="$value" ;;
            template_name)  TEMPLATE_NAME="$value" ;;
            storage)        STORAGE="$value" ;;
            disk_size)      DISK_SIZE="$value" ;;
            memory)         MEMORY="$value" ;;
            cores)          CORES="$value" ;;
            bridge)         BRIDGE="$value" ;;
            tags)           TAGS="$value" ;;
            kernel)         KERNEL="$value" ;;
            append)         APPEND="$value" ;;
        esac
    done < <(grep -v '^#\|^\[' "$conf" | grep '=')
}

list_templates() {
    log "Existing microvm templates:"
    qm list 2>/dev/null | while read -r vmid name status mem pid; do
        [ "$vmid" = "VMID" ] && continue
        conf="/etc/pve/qemu-server/${vmid}.conf"
        [ -f "$conf" ] || continue
        if grep -q 'machine:.*microvm' "$conf" 2>/dev/null && grep -q 'template:' "$conf" 2>/dev/null; then
            echo "  VMID $vmid  name=$name  status=$status"
        fi
    done
}

REFRESH=0
ACTION="create"

# Parse args
load_config
while [[ $# -gt 0 ]]; do
    case "$1" in
        --image)     IMAGE="$2"; shift 2 ;;
        --vmid)      TEMPLATE_VMID="$2"; shift 2 ;;
        --name)      TEMPLATE_NAME="$2"; shift 2 ;;
        --storage)   STORAGE="$2"; shift 2 ;;
        --disk-size) DISK_SIZE="$2"; shift 2 ;;
        --profile)   PROFILE="$2"; shift 2 ;;
        --no-docker) INSTALL_DOCKER=0; shift ;;
        --no-ssh)    INSTALL_SSH=0; shift ;;
        --no-agent)  INSTALL_AGENT=0; shift ;;
        --list)      ACTION="list"; shift ;;
        --refresh)   REFRESH=1; shift ;;
        --help|-h)   usage 0 ;;
        *)           die "unknown argument: $1" ;;
    esac
done

# Apply profile presets
case "$PROFILE" in
    minimal)
        INSTALL_DOCKER=0; INSTALL_SSH=0; INSTALL_AGENT=0
        log "Profile: minimal (no docker, no ssh, no agent)"
        ;;
    standard|"")
        # standard is the default — docker off, ssh+agent on
        INSTALL_DOCKER=0
        ;;
    full)
        INSTALL_DOCKER=1; INSTALL_SSH=1; INSTALL_AGENT=1
        log "Profile: full (docker + ssh + agent)"
        ;;
    *) die "unknown profile: $PROFILE (use minimal, standard, or full)" ;;
esac

if [ "$ACTION" = "list" ]; then
    list_templates
    exit 0
fi

# Check if template already exists
if qm config "$TEMPLATE_VMID" >/dev/null 2>&1; then
    if [ "$REFRESH" -eq 0 ]; then
        log "Template VM $TEMPLATE_VMID already exists. Use --refresh to recreate."
        exit 0
    fi
    log "Removing existing template $TEMPLATE_VMID"
    qm destroy "$TEMPLATE_VMID" --purge 2>/dev/null || true
fi

# Validate tools
for tool in skopeo umoci qemu-img mkfs.ext4; do
    command -v "$tool" >/dev/null 2>&1 || die "required tool not found: $tool"
done

if [ ! -f "$KERNEL" ]; then
    # Fallback to host kernel
    KERNEL="/boot/vmlinuz-$(uname -r)"
    INITRD="/boot/initrd.img-$(uname -r)"
    [ -f "$KERNEL" ] || die "no kernel found (neither shipped nor host)"
    log "Using host kernel: $KERNEL"
fi

log "Creating microvm template from $IMAGE"
log "  VMID:    $TEMPLATE_VMID"
log "  Name:    $TEMPLATE_NAME"
log "  Storage: $STORAGE"
log "  Disk:    $DISK_SIZE"

# Work directory
mkdir -p "$CACHE_DIR"
WORKDIR=$(mktemp -d "$CACHE_DIR/build.XXXXXX")
trap 'rm -rf "$WORKDIR"' EXIT

# ── 9Front special case: download pre-built qcow2 directly ──────
if echo "$IMAGE" | grep -qi '^9front'; then
    log "9Front image detected — downloading pre-built qcow2"
    NFRONT_URL="https://9front.org/iso/9front-11554.amd64.qcow2.gz"
    NFRONT_GZ="$WORKDIR/9front.qcow2.gz"
    NFRONT_QCOW2="$WORKDIR/9front.qcow2"

    log "Downloading from $NFRONT_URL (239 MB compressed)..."

    log "Decompressing..."
    gunzip "$NFRONT_GZ"
    ls -lh "$NFRONT_QCOW2"

    # Create the VM — 9front boots from disk via BIOS, not -kernel
    # Use q35 machine type (not microvm) since 9front needs BIOS boot
    log "Creating 9Front template VM $TEMPLATE_VMID..."
    qm create "$TEMPLATE_VMID" \
        --machine q35 \
        --name "$TEMPLATE_NAME" \
        --memory "$MEMORY" \
        --cores "$CORES" \
        --net0 "virtio,bridge=$BRIDGE" \
        --serial0 socket \
        --vga serial0 \
        --tags "$TAGS,9front"
    qm set "$TEMPLATE_VMID" --delete vmgenid --delete smbios1 2>/dev/null || true

    # Import the qcow2
    log "Importing disk to $STORAGE..."
    IMPORT_OUTPUT=$(qm importdisk "$TEMPLATE_VMID" "$NFRONT_QCOW2" "$STORAGE" --format qcow2 2>&1)
    IMPORT_VOLID=$(echo "$IMPORT_OUTPUT" | grep -oP "successfully imported disk '\K[^']+" || echo "$STORAGE:vm-${TEMPLATE_VMID}-disk-0")
    log "Imported: $IMPORT_VOLID"
    qm set "$TEMPLATE_VMID" --scsi0 "$IMPORT_VOLID" --boot order=scsi0

    # 9front serial console: append console=0 to plan9.ini
    # (handled by the 9front boot loader when serial is available)

    # Convert to template
    log "Converting to template..."
    qm template "$TEMPLATE_VMID"

    log ""
    log "=== 9Front template ready ==="
    log ""
    log "Clone:"
    log "  qm clone $TEMPLATE_VMID <new-vmid> --name my-9front --full"
    log "  qm start <new-vmid>"
    log "  qm terminal <new-vmid>"
    log ""
    log "Note: 9Front boots from disk (no -kernel needed)."
    log "Serial console: at the boot prompt, type: console=0"
    log "Or edit plan9.ini inside the guest to add: console=0"
    exit 0
fi

# ── OSv unikernel special case ──────────────────────────────────
if echo "$IMAGE" | grep -qi '^osv'; then
    log "OSv unikernel detected — downloading kernel loader"
    OSV_URL="https://github.com/cloudius-systems/osv/releases/download/v0.57.0/osv-loader.elf.x86_64.gz"
    OSV_GZ="$WORKDIR/osv-loader.elf.gz"
    OSV_KERNEL="$WORKDIR/osv-loader.elf"

    log "Downloading OSv loader (2.5 MB compressed)..."
    gunzip "$OSV_GZ" || die "download failed"

    # OSv boots via -kernel with its own loader
    log "Creating OSv template VM $TEMPLATE_VMID..."
    qm create "$TEMPLATE_VMID" \
        --machine q35 \
        --name "$TEMPLATE_NAME" \
        --memory "$MEMORY" \
        --cores "$CORES" \
        --net0 "virtio,bridge=$BRIDGE" \
        --serial0 socket \
        --vga serial0 \
        --tags "$TAGS,osv,unikernel"
    qm set "$TEMPLATE_VMID" --delete vmgenid --delete smbios1 2>/dev/null || true

    # Install OSv loader as the kernel
    install -m 644 "$OSV_KERNEL" /usr/share/pve-microvm/osv-loader
    qm set "$TEMPLATE_VMID" --args "-kernel /usr/share/pve-microvm/osv-loader -append \"--noinit --verbose\""

    log "Converting to template..."
    qm template "$TEMPLATE_VMID"

    log ""
    log "=== OSv template ready ==="
    log "OSv is a unikernel — it runs a single application per VM."
    log "Use the OSv capstan/ops tools to build application images,"
    log "then import them as disks for the cloned VM."
    exit 0
fi

# ── gokrazy special case ────────────────────────────────────
if echo "$IMAGE" | grep -qi '^gokrazy'; then
    log "gokrazy detected"
    log ""
    log "gokrazy builds are created with the gok CLI tool, not from OCI images."
    log "To create a gokrazy microvm:"
    log ""
    log "  1. Install gok: go install github.com/gokrazy/tools/cmd/gok@latest"
    log "  2. Create instance: gok -i virtual new"
    log "  3. Build image: gok -i virtual overwrite --full /tmp/gokrazy.img"
    log "  4. Import to PVE:"
    log "     qm create $TEMPLATE_VMID --machine q35 --memory $MEMORY --cores $CORES \\"
    log "       --net0 virtio,bridge=$BRIDGE --serial0 socket --vga serial0"
    log "     qm importdisk $TEMPLATE_VMID /tmp/gokrazy.img $STORAGE"
    log "     qm set $TEMPLATE_VMID --scsi0 $STORAGE:vm-${TEMPLATE_VMID}-disk-0 --boot order=scsi0"
    log "     qm template $TEMPLATE_VMID"
    log ""
    log "gokrazy boots from disk via BIOS (q35 machine type)."
    log "Serial console works with -nographic."
    log "See: https://gokrazy.org/userguide/qemu/"
    exit 0
fi

# ── OpenWrt ──────────────────────────────────────────────────────
if echo "$IMAGE" | grep -qi '^openwrt'; then
    log "OpenWrt detected — downloading x86-64 combined image"
    OPENWRT_VER="25.12.2"
    OPENWRT_URL="https://downloads.openwrt.org/releases/${OPENWRT_VER}/targets/x86/64/openwrt-${OPENWRT_VER}-x86-64-generic-ext4-combined.img.gz"
    OPENWRT_GZ="$WORKDIR/openwrt.img.gz"
    OPENWRT_IMG="$WORKDIR/openwrt.img"

    log "Downloading OpenWrt $OPENWRT_VER (13 MB compressed)..."
    curl -sL "$OPENWRT_URL" -o "$OPENWRT_GZ" || die "download failed"
    gunzip "$OPENWRT_GZ" || die "decompress failed"

    log "Creating OpenWrt template VM $TEMPLATE_VMID..."
    qm create "$TEMPLATE_VMID" \
        --machine q35 \
        --memory "${MEMORY:-256}" \
        --cores "${CORES:-1}" \
        --name "${TEMPLATE_NAME:-microvm-openwrt}" \
        --serial0 socket --vga serial0 \
        --net0 virtio,bridge=vmbr0 \
        --tags "$TAGS,openwrt" 2>&1 || die "qm create failed"

    log "Importing disk..."
    IMPORT_OUT=$(qm importdisk "$TEMPLATE_VMID" "$OPENWRT_IMG" "$STORAGE" 2>&1)
    VOLID=$(echo "$IMPORT_OUT" | grep -oP "unused0: successfully imported disk '\K[^']+")
    [ -z "$VOLID" ] && VOLID="${STORAGE}:vm-${TEMPLATE_VMID}-disk-0"

    qm set "$TEMPLATE_VMID" --ide0 "$VOLID" --boot order=ide0 2>&1

    log "Converting to template..."
    qm template "$TEMPLATE_VMID" 2>&1

    log "=== Template ready ==="
    log ""
    log "Clone a new OpenWrt instance:"
    log "  qm clone $TEMPLATE_VMID <new-vmid> --name my-openwrt --full"
    log ""
    log "Start and connect:"
    log "  qm start <new-vmid>"
    log "  qm terminal <new-vmid>"
    log ""
    log "Press Enter at the console to activate the shell."
    log "Default LAN: 192.168.1.1 — configure via UCI or LuCI."
    cleanup
    exit 0
fi

# ── OPNsense ─────────────────────────────────────────────────────
if echo "$IMAGE" | grep -qi '^opnsense'; then
    log "OPNsense detected — downloading serial image"
    OPNSENSE_VER="25.1"
    OPNSENSE_MIRROR="https://mirror.ams1.nl.leaseweb.net/opnsense/releases/${OPNSENSE_VER}"
    OPNSENSE_FILE="OPNsense-${OPNSENSE_VER}-serial-amd64.img.bz2"
    OPNSENSE_BZ2="$WORKDIR/opnsense.img.bz2"
    OPNSENSE_IMG="$WORKDIR/opnsense.img"

    log "Downloading OPNsense $OPNSENSE_VER (~500 MB compressed)..."
    log "This may take several minutes."
    curl -sL "${OPNSENSE_MIRROR}/${OPNSENSE_FILE}" -o "$OPNSENSE_BZ2" || die "download failed"
    log "Decompressing (~2.5 GB)..."
    bunzip2 "$OPNSENSE_BZ2" || die "decompress failed"

    log "Creating OPNsense template VM $TEMPLATE_VMID..."
    qm create "$TEMPLATE_VMID" \
        --machine q35 \
        --memory "${MEMORY:-1024}" \
        --cores "${CORES:-2}" \
        --name "${TEMPLATE_NAME:-microvm-opnsense}" \
        --serial0 socket --vga serial0 \
        --net0 virtio,bridge=vmbr0 \
        --tags "$TAGS,opnsense,freebsd" 2>&1 || die "qm create failed"

    log "Importing disk (2.5 GB)..."
    IMPORT_OUT=$(qm importdisk "$TEMPLATE_VMID" "$OPNSENSE_IMG" "$STORAGE" 2>&1)
    VOLID=$(echo "$IMPORT_OUT" | grep -oP "unused0: successfully imported disk '\K[^']+")
    [ -z "$VOLID" ] && VOLID="${STORAGE}:vm-${TEMPLATE_VMID}-disk-0"

    qm set "$TEMPLATE_VMID" --ide0 "$VOLID" --boot order=ide0 2>&1

    log "Converting to template..."
    qm template "$TEMPLATE_VMID" 2>&1

    log "=== Template ready ==="
    log ""
    log "Clone a new OPNsense instance:"
    log "  qm clone $TEMPLATE_VMID <new-vmid> --name my-opnsense --full"
    log ""
    log "Start and connect (needs >= 1 GB RAM):"
    log "  qm set <new-vmid> --memory 1024"
    log "  qm start <new-vmid>"
    log "  qm terminal <new-vmid>"
    log ""
    log "Default credentials: root / opnsense"
    log "Web UI: https://<LAN-IP>/"
    cleanup
    exit 0
fi

OCI_DIR="$WORKDIR/oci"
BUNDLE_DIR="$WORKDIR/bundle"
ROOTFS_DIR="$BUNDLE_DIR/rootfs"

# Step 1: Pull image
log "Pulling $IMAGE..."
FULL_IMAGE="$IMAGE"
[[ "$FULL_IMAGE" == *"/"* ]] || FULL_IMAGE="docker.io/library/$FULL_IMAGE"
skopeo copy "docker://$FULL_IMAGE" "oci:$OCI_DIR:latest" >/dev/null 2>&1

# Step 2: Unpack
log "Unpacking rootfs..."
umoci unpack --image "$OCI_DIR:latest" "$BUNDLE_DIR" >/dev/null 2>&1

# Step 3: Prepare for microvm boot
log "Preparing rootfs..."
for dir in proc sys dev dev/pts run tmp sbin usr/local/bin usr/sbin; do
    mkdir -p "$ROOTFS_DIR/$dir"
done

# Install init system for the rootfs
MICROVM_INIT="/usr/share/pve-microvm/microvm-init"

if [ -d "$ROOTFS_DIR/lib/systemd/system" ] && [ -f "$ROOTFS_DIR/lib/systemd/systemd" ]; then
    log "systemd detected — configuring for serial console"
    mkdir -p "$ROOTFS_DIR/etc/systemd/system/getty.target.wants"
    ln -sf /lib/systemd/system/serial-getty@.service \
        "$ROOTFS_DIR/etc/systemd/system/getty.target.wants/serial-getty@ttyS0.service" 2>/dev/null || true
    sed -i 's|^root:[^:]*:|root::|' "$ROOTFS_DIR/etc/shadow" 2>/dev/null || true

elif [ -f "$ROOTFS_DIR/bin/busybox" ]; then
    log "busybox detected — configuring inittab for ttyS0"
    mkdir -p "$ROOTFS_DIR/sbin"
    [ -f "$ROOTFS_DIR/sbin/init" ] || ln -sf ../bin/busybox "$ROOTFS_DIR/sbin/init"
    cat > "$ROOTFS_DIR/etc/inittab" <<'INITTAB'
::sysinit:/bin/mount -t proc proc /proc
::sysinit:/bin/mount -t sysfs sys /sys
::sysinit:/bin/mount -t devtmpfs dev /dev
::sysinit:/bin/mkdir -p /dev/pts
::sysinit:/bin/mount -t devpts devpts /dev/pts
::sysinit:/bin/hostname microvm
ttyS0::respawn:/bin/sh
::shutdown:/bin/umount -a -r
INITTAB

else
    log "no init found — installing microvm-init"
    if [ -f "$MICROVM_INIT" ]; then
        install -m 755 "$MICROVM_INIT" "$ROOTFS_DIR/sbin/microvm-init"
        ln -sf microvm-init "$ROOTFS_DIR/sbin/init"
    fi
fi

# Set empty root password for serial login
if [ -f "$ROOTFS_DIR/etc/shadow" ]; then
    sed -i 's|^root:[^:]*:|root::|' "$ROOTFS_DIR/etc/shadow" 2>/dev/null || true
fi

# Install the setup script for first-boot package installation
MICROVM_SETUP="/usr/share/pve-microvm/microvm-setup"
if [ -f "$MICROVM_SETUP" ]; then
    log "Installing first-boot setup script..."
    install -m 755 "$MICROVM_SETUP" "$ROOTFS_DIR/usr/local/bin/microvm-setup"

    # Create profile flag files for the setup script
    [ "$INSTALL_DOCKER" -eq 0 ] && touch "$ROOTFS_DIR/etc/microvm-no-docker"

    # Create a systemd service to run it on first boot (if systemd will be used)
    if [ -d "$ROOTFS_DIR/etc/systemd/system" ] || [ -d "$ROOTFS_DIR/lib/systemd" ]; then
        mkdir -p "$ROOTFS_DIR/etc/systemd/system/multi-user.target.wants"
        cat > "$ROOTFS_DIR/etc/systemd/system/microvm-setup.service" <<'SVCUNIT'
[Unit]
Description=microvm first-boot setup
ConditionPathExists=!/etc/microvm-setup-done
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/microvm-setup
RemainAfterExit=yes
TimeoutStartSec=300

[Install]
WantedBy=multi-user.target
SVCUNIT
        ln -sf ../microvm-setup.service \
            "$ROOTFS_DIR/etc/systemd/system/multi-user.target.wants/microvm-setup.service"
    else
        # For non-systemd: add to microvm-init's boot sequence
        # The setup will run when the user manually calls it
        log "No systemd — run 'microvm-setup' manually after first boot"
    fi
fi

# DNS defaults (needed for chroot package install)
[ -f "$ROOTFS_DIR/etc/resolv.conf" ] || echo "nameserver 1.1.1.1" > "$ROOTFS_DIR/etc/resolv.conf"

# Step 4: Install essential packages via chroot
# trixie-slim has no networking tools — install them at build time
if [ -f "$ROOTFS_DIR/usr/bin/apt-get" ] || [ -f "$ROOTFS_DIR/usr/bin/dpkg" ]; then
    log "Installing base packages via chroot..."

    # Bind-mount host resources for chroot
    mount --bind /proc "$ROOTFS_DIR/proc" 2>/dev/null || true
    mount --bind /sys "$ROOTFS_DIR/sys" 2>/dev/null || true
    mount --bind /dev "$ROOTFS_DIR/dev" 2>/dev/null || true
    mount --bind /dev/pts "$ROOTFS_DIR/dev/pts" 2>/dev/null || true

    # Ensure apt sources exist
    if [ ! -f "$ROOTFS_DIR/etc/apt/sources.list" ] && \
       [ -z "$(find "$ROOTFS_DIR/etc/apt/sources.list.d" -name '*.sources' -o -name '*.list' 2>/dev/null)" ]; then
        mkdir -p "$ROOTFS_DIR/etc/apt/sources.list.d"
        cat > "$ROOTFS_DIR/etc/apt/sources.list.d/debian.sources" <<'APTSRC'
Types: deb
URIs: http://deb.debian.org/debian
Suites: trixie trixie-updates
Components: main
Signed-By: /usr/share/keyrings/debian-archive-keyring.gpg
APTSRC
    fi

    # Build package list based on profile flags
    PKGS="iproute2 isc-dhcp-client systemd systemd-sysv ca-certificates curl cloud-init"
    [ "$INSTALL_SSH" -eq 1 ] && PKGS="$PKGS openssh-server"
    [ "$INSTALL_AGENT" -eq 1 ] && PKGS="$PKGS qemu-guest-agent"
    log "Packages: $PKGS"

    # Install packages
    chroot "$ROOTFS_DIR" /bin/bash -c "
        export DEBIAN_FRONTEND=noninteractive
        apt-get update -qq 2>/dev/null
        apt-get install -y -qq --no-install-recommends $PKGS 2>/dev/null

        # Enable essential services
        systemctl enable serial-getty@ttyS0.service 2>/dev/null || true
        systemctl enable cloud-init 2>/dev/null || true
        systemctl enable systemd-networkd 2>/dev/null || true
        systemctl enable systemd-resolved 2>/dev/null || true

        # DHCP fallback
        printf '[Unit]\nDescription=DHCP on eth0\nAfter=network.target\nWants=network.target\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStartPre=/sbin/ip link set eth0 up\nExecStart=/usr/sbin/dhclient -4 eth0\nExecStop=/usr/sbin/dhclient -r eth0\n\n[Install]\nWantedBy=multi-user.target\n' > /etc/systemd/system/microvm-dhcp.service
        systemctl enable microvm-dhcp.service 2>/dev/null || true

        # Custom serial console service
        systemctl disable serial-getty@ttyS0.service 2>/dev/null || true
        printf '[Unit]\nDescription=microvm serial console\nAfter=systemd-user-sessions.service\n\n[Service]\nExecStart=-/sbin/agetty --autologin root --noclear ttyS0 linux\nRestart=always\nRestartSec=0\nType=idle\n\n[Install]\nWantedBy=multi-user.target\n' > /etc/systemd/system/microvm-console.service
        systemctl enable microvm-console.service 2>/dev/null || true

        # Configure cloud-init for PVE nocloud
        mkdir -p /etc/cloud/cloud.cfg.d
        printf 'datasource_list: [NoCloud, ConfigDrive, None]\ndatasource:\n  NoCloud:\n    fs_label: cidata\n' > /etc/cloud/cloud.cfg.d/99-pve.cfg

        # Set empty root password
        sed -i 's|^root:[^:]*:|root::|' /etc/shadow 2>/dev/null || true

        # Clean up
        apt-get clean 2>/dev/null || true
        rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*
    " 2>&1 || log "warning: chroot package install had errors"

    # Conditional services -- run as separate chroot commands
    # so we can use shell variables
    if [ "$INSTALL_SSH" -eq 1 ]; then
        chroot "$ROOTFS_DIR" systemctl enable ssh 2>/dev/null || true
    fi

    if [ "$INSTALL_AGENT" -eq 1 ]; then
        chroot "$ROOTFS_DIR" bash -c '
            systemctl mask qemu-guest-agent.service 2>/dev/null || true
            printf "[Unit]\nDescription=QEMU Guest Agent for microvm\nAfter=multi-user.target\n\n[Service]\nExecStart=-/usr/sbin/qemu-ga --method=virtio-serial --path=/dev/vport1p1\nRestart=always\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\n" > /etc/systemd/system/microvm-agent.service
            systemctl enable microvm-agent.service 2>/dev/null || true
        ' 2>/dev/null || true
    fi

    # Unmount
    umount "$ROOTFS_DIR/dev/pts" 2>/dev/null || true
    umount "$ROOTFS_DIR/dev" 2>/dev/null || true
    umount "$ROOTFS_DIR/sys" 2>/dev/null || true
    umount "$ROOTFS_DIR/proc" 2>/dev/null || true

    log "Base packages installed."
elif [ -f "$ROOTFS_DIR/sbin/apk" ] || [ -f "$ROOTFS_DIR/usr/bin/apk" ]; then
    log "Installing base packages via chroot (Alpine)..."

    mount --bind /proc "$ROOTFS_DIR/proc" 2>/dev/null || true
    mount --bind /sys "$ROOTFS_DIR/sys" 2>/dev/null || true
    mount --bind /dev "$ROOTFS_DIR/dev" 2>/dev/null || true

    chroot "$ROOTFS_DIR" /bin/sh -c '
        # Alpine: install essentials via apk
        apk update 2>/dev/null
        APKPKGS="dhclient socat cloud-init"
    ' 2>&1 || true

    # Conditional Alpine packages
    APKPKGS="dhclient socat cloud-init"
    [ "$INSTALL_SSH" -eq 1 ] && APKPKGS="$APKPKGS openssh"
    [ "$INSTALL_AGENT" -eq 1 ] && APKPKGS="$APKPKGS qemu-guest-agent"
    chroot "$ROOTFS_DIR" /bin/sh -c "apk add --no-cache $APKPKGS 2>/dev/null" || true

    chroot "$ROOTFS_DIR" /bin/sh -c '
        # Enable services via OpenRC
        if command -v rc-update >/dev/null 2>&1; then
            rc-update add networking default 2>/dev/null || true
        fi

        # Set empty root password
        sed -i "s|^root:[^:]*:|root::|" /etc/shadow 2>/dev/null || true
    ' 2>&1 || log "warning: chroot package install had errors"

    if [ "$INSTALL_SSH" -eq 1 ]; then
        chroot "$ROOTFS_DIR" rc-update add sshd default 2>/dev/null || true
    fi
    if [ "$INSTALL_AGENT" -eq 1 ]; then
        chroot "$ROOTFS_DIR" rc-update add qemu-guest-agent default 2>/dev/null || true
    fi

    umount "$ROOTFS_DIR/dev" 2>/dev/null || true
    umount "$ROOTFS_DIR/sys" 2>/dev/null || true
    umount "$ROOTFS_DIR/proc" 2>/dev/null || true

    log "Alpine packages installed."
elif [ -f "$ROOTFS_DIR/usr/bin/dnf" ] || [ -f "$ROOTFS_DIR/usr/bin/microdnf" ] || [ -f "$ROOTFS_DIR/usr/bin/tdnf" ] || [ -f "$ROOTFS_DIR/usr/bin/yum" ]; then
    log "Installing base packages via chroot (dnf/yum/tdnf)..."

    mount --bind /proc "$ROOTFS_DIR/proc" 2>/dev/null || true
    mount --bind /sys "$ROOTFS_DIR/sys" 2>/dev/null || true
    mount --bind /dev "$ROOTFS_DIR/dev" 2>/dev/null || true

    # Detect package manager
    if [ -f "$ROOTFS_DIR/usr/bin/dnf" ]; then
        PKG_CMD="dnf"
    elif [ -f "$ROOTFS_DIR/usr/bin/microdnf" ]; then
        PKG_CMD="microdnf"
    elif [ -f "$ROOTFS_DIR/usr/bin/tdnf" ]; then
        PKG_CMD="tdnf"
    else
        PKG_CMD="yum"
    fi

    # Build package list
    DNFPKGS="iproute dhcp-client systemd cloud-init"
    [ "$INSTALL_SSH" -eq 1 ] && DNFPKGS="$DNFPKGS openssh-server"
    [ "$INSTALL_AGENT" -eq 1 ] && DNFPKGS="$DNFPKGS qemu-guest-agent"
    log "Packages ($PKG_CMD): $DNFPKGS"

    chroot "$ROOTFS_DIR" /bin/bash -c "
        $PKG_CMD install -y $DNFPKGS 2>/dev/null || true

        # Enable services
        systemctl enable systemd-networkd 2>/dev/null || true
        systemctl enable cloud-init 2>/dev/null || true

        # Serial console
        systemctl disable serial-getty@ttyS0.service 2>/dev/null || true
        printf '[Unit]\\nDescription=microvm serial console\\nAfter=systemd-user-sessions.service\\n\\n[Service]\\nExecStart=-/sbin/agetty --autologin root --noclear ttyS0 linux\\nRestart=always\\nRestartSec=0\\nType=idle\\n\\n[Install]\\nWantedBy=multi-user.target\\n' > /etc/systemd/system/microvm-console.service
        systemctl enable microvm-console.service 2>/dev/null || true

        # DHCP fallback
        printf '[Unit]\\nDescription=DHCP on eth0\\nAfter=network.target\\n\\n[Service]\\nType=oneshot\\nRemainAfterExit=yes\\nExecStartPre=/sbin/ip link set eth0 up\\nExecStart=/usr/sbin/dhclient -4 eth0\\n\\n[Install]\\nWantedBy=multi-user.target\\n' > /etc/systemd/system/microvm-dhcp.service
        systemctl enable microvm-dhcp.service 2>/dev/null || true

        # Set empty root password
        sed -i 's|^root:[^:]*:|root::|' /etc/shadow 2>/dev/null || true

        # Clean
        $PKG_CMD clean all 2>/dev/null || true
    " 2>&1 || log "warning: chroot package install had errors"

    if [ "$INSTALL_SSH" -eq 1 ]; then
        chroot "$ROOTFS_DIR" systemctl enable sshd 2>/dev/null || true
    fi
    if [ "$INSTALL_AGENT" -eq 1 ]; then
        chroot "$ROOTFS_DIR" bash -c '
            systemctl mask qemu-guest-agent.service 2>/dev/null || true
            printf "[Unit]\nDescription=QEMU Guest Agent for microvm\nAfter=multi-user.target\n\n[Service]\nExecStart=-/usr/sbin/qemu-ga --method=virtio-serial --path=/dev/vport1p1\nRestart=always\nRestartSec=5\n\n[Install]\nWantedBy=multi-user.target\n" > /etc/systemd/system/microvm-agent.service
            systemctl enable microvm-agent.service 2>/dev/null || true
        ' 2>/dev/null || true
    fi

    umount "$ROOTFS_DIR/dev" 2>/dev/null || true
    umount "$ROOTFS_DIR/sys" 2>/dev/null || true
    umount "$ROOTFS_DIR/proc" 2>/dev/null || true

    log "RPM packages installed."
else
    log "No apt-get, apk, or dnf found — skipping chroot package install"
fi

# Step 4: Create disk image
log "Creating $DISK_SIZE disk..."
RAW="$WORKDIR/disk.raw"
truncate -s "$DISK_SIZE" "$RAW"
mkfs.ext4 -F -L microvm-root -d "$ROOTFS_DIR" "$RAW" >/dev/null 2>&1

QCOW2="$WORKDIR/disk.qcow2"
qemu-img convert -f raw -O qcow2 "$RAW" "$QCOW2"

# Step 5: Create template VM
log "Creating template VM $TEMPLATE_VMID..."
KERNEL_ARGS="-kernel $KERNEL -append \"$APPEND\""
if [ -n "$INITRD" ] && [ -f "$INITRD" ]; then
    KERNEL_ARGS="-kernel $KERNEL -initrd $INITRD -append \"$APPEND\""
fi

qm create "$TEMPLATE_VMID" \
    --machine microvm \
    --name "$TEMPLATE_NAME" \
    --memory "$MEMORY" \
    --cores "$CORES" \
    --net0 "virtio,bridge=$BRIDGE" \
    --serial0 socket \
    --vga serial0 \
    --agent 1 \
    --tags "$TAGS" \
    --args "$KERNEL_ARGS"

# Remove options that microvm doesn't support (auto-set by qm create)
qm set "$TEMPLATE_VMID" --delete vmgenid --delete smbios1 2>/dev/null || true

# Step 6: Import disk
log "Importing disk to $STORAGE..."
IMPORT_OUTPUT=$(qm importdisk "$TEMPLATE_VMID" "$QCOW2" "$STORAGE" --format qcow2 2>&1)
IMPORT_VOLID=$(echo "$IMPORT_OUTPUT" | grep -oP "successfully imported disk '\K[^']+" || echo "$STORAGE:vm-${TEMPLATE_VMID}-disk-0")
log "Imported disk: $IMPORT_VOLID"
qm set "$TEMPLATE_VMID" --scsi0 "$IMPORT_VOLID"

# Step 7: Add cloud-init drive
log "Adding cloud-init drive..."
qm set "$TEMPLATE_VMID" --scsi1 "$STORAGE:cloudinit" 2>/dev/null || \
    log "warning: could not add cloud-init drive"

# Set cloud-init defaults
qm set "$TEMPLATE_VMID" --ciuser root --ipconfig0 ip=dhcp 2>/dev/null || true

# Step 8: Convert to template
log "Converting to template..."
qm template "$TEMPLATE_VMID"

log ""
log "=== Template ready ==="
log ""
log "Clone a new microvm:"
log "  qm clone $TEMPLATE_VMID <new-vmid> --name my-sandbox --full"
log ""
log "Set SSH key (optional):"
log "  qm set <new-vmid> --sshkeys ~/.ssh/authorized_keys"
log ""
log "Start and connect:"
log "  qm start <new-vmid>"
log "  qm terminal <new-vmid>"
