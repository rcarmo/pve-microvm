#!/bin/bash
# pve-microvm-patch — apply or revert pve-microvm patches to qemu-server
#
# Usage:
#   pve-microvm-patch apply    — back up originals and apply patches
#   pve-microvm-patch revert   — restore originals from backup
#   pve-microvm-patch status   — show whether patches are applied

set -euo pipefail

BACKUP_DIR="/usr/share/pve-microvm/backup"
MICROVM_MODULE="/usr/share/perl5/PVE/QemuServer/MicroVM.pm"
QEMU_SERVER_DIR="/usr/share/perl5/PVE/QemuServer"
QEMU_SERVER_PM="/usr/share/perl5/PVE/QemuServer.pm"
MACHINE_PM="${QEMU_SERVER_DIR}/Machine.pm"
PVE_CSS_DIR="/usr/share/pve-manager/css"
PVE_JS_DIR="/usr/share/pve-manager/js"
INDEX_TPL="/usr/share/pve-manager/index.html.tpl"

STAMP="/usr/share/pve-microvm/.applied"

log() { echo "pve-microvm: $*"; }
die() { echo "pve-microvm: ERROR: $*" >&2; exit 1; }

cmd_apply() {
    if [ -f "$STAMP" ]; then
        log "patches already applied (stamp exists), skipping"
        return 0
    fi

    [ -f "$MACHINE_PM" ]     || die "Machine.pm not found at $MACHINE_PM"
    [ -f "$QEMU_SERVER_PM" ] || die "QemuServer.pm not found at $QEMU_SERVER_PM"

    mkdir -p "$BACKUP_DIR"

    log "backing up originals to $BACKUP_DIR"
    cp -a "$MACHINE_PM" "$BACKUP_DIR/Machine.pm.orig"
    cp -a "$QEMU_SERVER_PM" "$BACKUP_DIR/QemuServer.pm.orig"

    # ── Patch Machine.pm ─────────────────────────────────────────
    log "patching Machine.pm"

    python3 << 'PATCHMACHINE'
import sys

path = "/usr/share/perl5/PVE/QemuServer/Machine.pm"
with open(path) as f:
    text = f.read()

original = text
changes = []

# 1. Add |microvm to the machine type regex
old_re = r"virt(?:-\d+(\.\d+)+)?(\+pve\d+)?)"
new_re = r"virt(?:-\d+(\.\d+)+)?(\+pve\d+)?|microvm)"
if old_re in text:
    text = text.replace(old_re, new_re, 1)
    changes.append("regex patched")
else:
    changes.append("regex already patched or not found")

# 2. Add microvm to machine_base_type()
marker = "    return 'virt' if "
if marker in text and "'microvm'" not in text:
    lines = text.split("\n")
    out = []
    for line in lines:
        out.append(line)
        if line.strip().startswith("return 'virt' if"):
            out.append("    return 'microvm' if $machine_type =~ m/^microvm/;")
    text = "\n".join(out)
    changes.append("machine_base_type patched")
else:
    changes.append("machine_base_type already patched or not found")

# 3. Add microvm to supported_machine_flags
if "virt => {}" in text and "microvm => {}" not in text:
    text = text.replace("    virt => {},", "    virt => {},\n    microvm => {},")
    changes.append("machine_flags patched")
else:
    changes.append("machine_flags already patched or not found")

# 4. Make get_vm_machine() return 'microvm' directly without +pve0 append
# Insert early return before the +pve0 logic
marker_pve0 = "    if ($machine !~ m/\\+pve\\d+?(?:\\.pxe)?$/)"
if marker_pve0 in text and "microvm" not in text.split(marker_pve0)[0].split("sub get_vm_machine")[-1]:
    text = text.replace(
        marker_pve0,
        "    # pve-microvm: microvm doesn't use +pveN versioning\n"
        "    return $machine if $machine =~ m/^microvm/;\n\n"
        + marker_pve0
    )
    changes.append("get_vm_machine patched")
else:
    changes.append("get_vm_machine already patched or marker not found")

with open(path, "w") as f:
    f.write(text)

for c in changes:
    print(f"  {c}")
PATCHMACHINE

    # ── Install MicroVM.pm ───────────────────────────────────────
    log "installing MicroVM.pm module"
    install -m 644 /usr/share/pve-microvm/MicroVM.pm "$MICROVM_MODULE"

    # ── Patch QemuServer.pm ──────────────────────────────────────
    log "patching QemuServer.pm"

    python3 << 'PATCHQS'
path = "/usr/share/perl5/PVE/QemuServer.pm"
with open(path) as f:
    lines = f.readlines()

out = []
added_use = False
added_check = False
for line in lines:
    # Add use statement
    if not added_use and line.startswith("use PVE::QemuServer::Machine;"):
        out.append(line)
        out.append("use PVE::QemuServer::MicroVM;\n")
        added_use = True
        continue

    # Add microvm delegation at start of config_to_command
    if not added_check and line.startswith("sub config_to_command {"):
        out.append(line)
        out.append("    # pve-microvm: delegate to microvm command builder\n")
        out.append("    if (PVE::QemuServer::MicroVM::is_microvm(($_[2]))) {\n")
        out.append("        return PVE::QemuServer::MicroVM::microvm_config_to_command(@_);\n")
        out.append("    }\n")
        added_check = True
        continue

    out.append(line)

with open(path, "w") as f:
    f.writelines(out)
print(f"  QemuServer.pm patched (use: {added_use}, delegate: {added_check})")
PATCHQS

    # ── Install UI ───────────────────────────────────────────────
    install_ui

    # ── Stamp ────────────────────────────────────────────────────
    date -Iseconds > "$STAMP"
    log "patches applied successfully"
}

install_ui() {
    if [ -d "$PVE_CSS_DIR" ]; then
        log "installing microvm CSS"
        install -m 644 /usr/share/pve-microvm/ui/pve-microvm.css "$PVE_CSS_DIR/pve-microvm.css"
    fi

    if [ -d "$PVE_JS_DIR" ]; then
        log "installing microvm JS"
        install -m 644 /usr/share/pve-microvm/ui/pve-microvm.js "$PVE_JS_DIR/pve-microvm.js"
    fi

    if [ -f "$INDEX_TPL" ]; then
        if ! grep -q 'pve-microvm.js' "$INDEX_TPL"; then
            log "injecting microvm JS into index.html.tpl"
            cp -a "$INDEX_TPL" "$BACKUP_DIR/index.html.tpl.orig"
            sed -i '/<\/head>/i \    <script type="text/javascript" src="/pve2/js/pve-microvm.js"><\/script>' "$INDEX_TPL"
        fi
    fi
}

cmd_revert() {
    if [ ! -f "$STAMP" ]; then
        log "patches not applied (no stamp), skipping"
        return 0
    fi

    log "reverting patches"

    [ -f "$BACKUP_DIR/Machine.pm.orig" ] && cp -a "$BACKUP_DIR/Machine.pm.orig" "$MACHINE_PM" && log "restored Machine.pm"
    [ -f "$BACKUP_DIR/QemuServer.pm.orig" ] && cp -a "$BACKUP_DIR/QemuServer.pm.orig" "$QEMU_SERVER_PM" && log "restored QemuServer.pm"
    [ -f "$BACKUP_DIR/index.html.tpl.orig" ] && cp -a "$BACKUP_DIR/index.html.tpl.orig" "$INDEX_TPL" && log "restored index.html.tpl"

    rm -f "$MICROVM_MODULE"
    rm -f "$PVE_CSS_DIR/pve-microvm.css" 2>/dev/null
    rm -f "$PVE_JS_DIR/pve-microvm.js" 2>/dev/null
    rm -rf "$BACKUP_DIR"
    rm -f "$STAMP"

    log "patches reverted successfully"
}

cmd_status() {
    if [ -f "$STAMP" ]; then
        echo "applied ($(cat "$STAMP"))"
    else
        echo "not applied"
    fi
}

case "${1:-}" in
    apply)  cmd_apply  ;;
    revert) cmd_revert ;;
    status) cmd_status ;;
    *)      echo "Usage: $0 {apply|revert|status}" >&2; exit 1 ;;
esac
