# pve-microvm kernel config overlay
#
# Applied on top of the Firecracker microvm-kernel-ci-x86_64-6.1.config base.
# These additions support Proxmox-specific features: guest agent channel,
# VLAN tagging, and cgroup v1/v2 controllers for container-in-VM workloads.
#
# Usage:
#   cp base-x86_64-6.1.config .config
#   scripts/kconfig/merge_config.sh -m .config pve-microvm-overlay.config
#   make olddefconfig
#   make -j$(nproc) vmlinux  # or bzImage

# ── VLAN support (Proxmox bridges often use VLAN tags) ──────────
CONFIG_VLAN_8021Q=y

# ── Cgroup controllers (for systemd guests and container workloads) ──
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_WRITEBACK=y
CONFIG_CGROUP_SCHED=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_BPF=y
CONFIG_CPUSETS=y

# ── Additional networking (useful for firewall/NAT inside guests) ──
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NETFILTER_XTABLES=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_NF_TABLES=y

# ── XFS (alternative rootfs) ────────────────────────────────────
CONFIG_XFS_FS=y

# ── ISO9660 + VFAT (required for cloud-init config drive) ─────
CONFIG_ISO9660_FS=y
CONFIG_JOLIET=y
CONFIG_VFAT_FS=y
CONFIG_FAT_FS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y

# ── Loop device (for mounting images inside guest) ──────────────
CONFIG_BLK_DEV_LOOP=y

# ── /dev/watchdog (for guest health monitoring) ─────────────────
CONFIG_WATCHDOG=y
CONFIG_SOFT_WATCHDOG=y

# ── Kernel modules support (optional, for flexibility) ──────────
# Leave disabled — we want everything built-in for direct kernel boot
# CONFIG_MODULES is not set
